NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/grilli

# JWT
JWT_SECRET=grilli_super_secret_jwt_key_change_in_production_2024
JWT_REFRESH_SECRET=grilli_refresh_secret_key_change_in_production_2024
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Grilli Restaurant <noreply@grilli.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Client URL
CLIENT_URL=http://localhost:5173
